{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/screen", "destination": "/api/screen" },
    { "source": "/api/batch-screen", "destination": "/api/batch-screen" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/", "destination": "/api/index" }
  ],
  "regions": ["iad1"],
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/batch-screen.js": {
      "memory": 2048,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
