{
  "version": 2,
  "buildCommand": "echo 'No build required'",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/screen", "destination": "/api/screen" },
    { "source": "/api/batch-screen", "destination": "/api/batch-screen" },
    { "source": "/api/health", "destination": "/api/health" }
  ],
  "regions": ["iad1"],
  "functions": {
    "api/screen.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/batch-screen.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/health.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
